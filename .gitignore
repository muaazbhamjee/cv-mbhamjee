# ── LaTeX build artefacts ──────────────────────────────────
*.aux
*.log
*.out
*.toc
*.lof
*.lot
*.fls
*.fdb_latexmk
*.synctex.gz
*.blg
*.bbl

# ── Auto-generated root-level files (built by build.py) ────
# Regenerate any time with: make
# These are working copies — the publishable copies live in docs/
cv_bhamjee.tex
*.pdf

# ── docs/ PDFs are explicitly UN-ignored ───────────────────
# Committed intentionally for GitHub Pages publishing.
# Push docs/ to github.io with: git add docs/ && git commit && git push
!docs/*.pdf

# ── OS clutter ─────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor files ───────────────────────────────────────────
*.swp
*.swo
*~
.vscode/
.idea/
